/dts-v1/;

#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/input/input.h>
#include <dt-bindings/interrupt-controller/irq.h>
#include <dt-bindings/interrupt-controller/arm-gic.h>
#include <dt-bindings/leds/common.h>

/ {
	compatible = "linkease,easepi-ars2", "realtek,rtd1296";
	model = "EasePi ARS2";
	interrupt-parent = <&gic>;
	#address-cells = <2>;
	#size-cells = <2>;

	chosen {
		stdout-path = "serial0:115200n8";
		default-ip = "192.168.88.100";
	};

	memory@0 {
		device_type = "memory";
		reg = <0x0 0x0 0x0 0x80000000>;
	};

	reserved-memory {
		#address-cells = <2>;
		#size-cells = <2>;
		ranges;

		secmon@07400000 {
			reg = <0x0 0x07400000 0x0 0x200000>;
			no-map;
		};
	};

	psci {
		compatible = "arm,psci-1.0";
		method = "smc";
	};

	cpus {
		#address-cells = <1>;
		#size-cells = <0>;

		cpu0: cpu@0 {
			device_type = "cpu";
			compatible = "arm,cortex-a53";
			reg = <0x0>;
			enable-method = "psci";
		};

		cpu1: cpu@1 {
			device_type = "cpu";
			compatible = "arm,cortex-a53";
			reg = <0x1>;
			enable-method = "psci";
		};

		cpu2: cpu@2 {
			device_type = "cpu";
			compatible = "arm,cortex-a53";
			reg = <0x2>;
			enable-method = "psci";
		};

		cpu3: cpu@3 {
			device_type = "cpu";
			compatible = "arm,cortex-a53";
			reg = <0x3>;
			enable-method = "psci";
		};
	};

	gic: interrupt-controller@10301000 {
		compatible = "arm,gic-v3";
		reg = <0x0 0x10301000 0x0 0x10000>,
		      <0x0 0x10302000 0x0 0x20000>,
		      <0x0 0x10304000 0x0 0x20000>,
		      <0x0 0x10306000 0x0 0x20000>;
		#interrupt-cells = <3>;
		interrupt-controller;
		#address-cells = <0>;
	};

	timer {
		compatible = "arm,armv8-timer";
		interrupts = <GIC_PPI 13 IRQ_TYPE_LEVEL_LOW>,
			     <GIC_PPI 14 IRQ_TYPE_LEVEL_LOW>,
			     <GIC_PPI 11 IRQ_TYPE_LEVEL_LOW>,
			     <GIC_PPI 10 IRQ_TYPE_LEVEL_LOW>;
	};

	clocks {
		#address-cells = <1>;
		#size-cells = <0>;

		uart_clk: uart-clk {
			compatible = "fixed-clock";
			clock-frequency = <24000000>;
			#clock-cells = <0>;
		};
	};

	pmu {
		compatible = "arm,cortex-a53-pmu";
		interrupts = <GIC_PPI 7 IRQ_TYPE_LEVEL_LOW>;
	};

	/* UART0 - Debug Port */
	serial0: serial@98000000 {
		compatible = "snps,dw-apb-uart";
		reg = <0x0 0x98000000 0x0 0x2000>;
		clocks = <&uart_clk>;
		status = "okay";
	};

	/* USB 2.0 Host */
	usb@9a00000 {
		compatible = "generic-xhci";
		reg = <0x0 0x9a00000 0x0 0x10000>;
		interrupts = <GIC_SPI 61 IRQ_TYPE_LEVEL_HIGH>;
		status = "okay";
	};

	/* USB 3.0 Host */
	usb@9b00000 {
		compatible = "generic-xhci";
		reg = <0x0 0x9b00000 0x0 0x10000>;
		interrupts = <GIC_SPI 62 IRQ_TYPE_LEVEL_HIGH>;
		status = "okay";
	};

	/* eMMC */
	mmc@98012000 {
		compatible = "realtek,rtd1296-emmc";
		reg = <0x0 0x98012000 0x0 0x8000>;
		interrupts = <GIC_SPI 57 IRQ_TYPE_LEVEL_HIGH>;
		status = "okay";
	};

	/* SD Card */
	sd0: sd@98013000 {
		compatible = "realtek,rtd1296-sdmmc";
		reg = <0x0 0x98013000 0x0 0x8000>;
		interrupts = <GIC_SPI 56 IRQ_TYPE_LEVEL_HIGH>;
		status = "disabled";
	};

	/* SATA */
	sata@9d10000 {
		compatible = "generic-ahci";
		reg = <0x0 0x9d10000 0x0 0x10000>;
		interrupts = <GIC_SPI 60 IRQ_TYPE_LEVEL_HIGH>;
		status = "okay";
	};

	/* GMAC (Ethernet) */
	gmac: ethernet@98016000 {
		compatible = "Realtek,r8168";
		reg = <0x0 0x98016000 0x0 0x1000>,
		      <0x0 0x98007000 0x0 0x1000>;
		interrupts = <GIC_SPI 22 IRQ_TYPE_LEVEL_HIGH>;
		rtl-config = <1>;
		mac-version = <42>;
		rtl-features = <2>;
		output-mode = <0>;
		status = "okay";
	};

	/* MISC GPIO */
	rtk_misc_gpio: gpio@9801b100 {
		compatible = "realtek,rtk-misc-gpio-irq-mux";
		gpio-controller;
		#gpio-cells = <3>;
		#interrupt-cells = <1>;
		interrupt-controller;
		reg = <0x0 0x9801b000 0x0 0x100>,
		      <0x0 0x9801b100 0x0 0x100>;
		ngpios = <101>;
		status = "okay";
	};

	/* ISO GPIO */
	rtk_iso_gpio: gpio@98007100 {
		compatible = "realtek,rtk-iso-gpio-irq-mux";
		gpio-controller;
		#gpio-cells = <3>;
		#interrupt-cells = <1>;
		interrupt-controller;
		reg = <0x0 0x98007000 0x0 0x100>,
		      <0x0 0x98007100 0x0 0x100>;
		ngpios = <35>;
		status = "okay";
	};

	/* LEDs */
	leds {
		compatible = "gpio-leds";

		led-power {
			label = "ars2:power";
			gpios = <&rtk_misc_gpio 47 GPIO_ACTIVE_LOW>;
			default-state = "on";
			linux,default-trigger = "default-on";
		};

		led-system {
			label = "ars2:system";
			gpios = <&rtk_misc_gpio 48 GPIO_ACTIVE_LOW>;
			default-state = "off";
			linux,default-trigger = "heartbeat";
		};
	};

	/* Buttons */
	gpio-keys {
		compatible = "gpio-keys";

		reset {
			label = "reset";
			gpios = <&rtk_misc_gpio 8 GPIO_ACTIVE_LOW>;
			linux,code = <KEY_RESTART>;
			debounce-interval = <50>;
		};
	};
};
