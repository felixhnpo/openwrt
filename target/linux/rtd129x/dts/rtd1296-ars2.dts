/dts-v1/;

#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/input/input.h>
#include <dt-bindings/interrupt-controller/irq.h>
#include <dt-bindings/interrupt-controller/arm-gic.h>

/ {
	compatible = "linkease,easepi-ars2", "realtek,rtd1296";
	model = "EasePi ARS2";
	interrupt-parent = <&gic>;
	#address-cells = <2>;
	#size-cells = <2>;

	chosen {
		stdout-path = "serial0:115200n8";
		default-ip = "192.168.88.100";
	};

	memory@0 {
		device_type = "memory";
		reg = <0x0 0x0 0x0 0x80000000>;
	};

	reserved-memory {
		#address-cells = <2>;
		#size-cells = <2>;
		ranges;

		secmon@07400000 {
			reg = <0x0 0x07400000 0x0 0x200000>;
			no-map;
		};
	};

	psci {
		compatible = "arm,psci-1.0";
		method = "smc";
	};

	cpus {
		#address-cells = <1>;
		#size-cells = <0>;

		cpu0: cpu@0 {
			device_type = "cpu";
			compatible = "arm,cortex-a53";
			reg = <0x0>;
			enable-method = "psci";
		};

		cpu1: cpu@1 {
			device_type = "cpu";
			compatible = "arm,cortex-a53";
			reg = <0x1>;
			enable-method = "psci";
		};

		cpu2: cpu@2 {
			device_type = "cpu";
			compatible = "arm,cortex-a53";
			reg = <0x2>;
			enable-method = "psci";
		};

		cpu3: cpu@3 {
			device_type = "cpu";
			compatible = "arm,cortex-a53";
			reg = <0x3>;
			enable-method = "psci";
		};
	};

	gic: interrupt-controller@10301000 {
		compatible = "arm,gic-v3";
		reg = <0x0 0x10301000 0x0 0x10000>,
		      <0x0 0x10302000 0x0 0x20000>,
		      <0x0 0x10304000 0x0 0x20000>,
		      <0x0 0x10306000 0x0 0x20000>;
		#interrupt-cells = <3>;
		interrupt-controller;
		#address-cells = <0>;
	};

	timer {
		compatible = "arm,armv8-timer";
		interrupts = <GIC_PPI 13 IRQ_TYPE_LEVEL_LOW>,
			     <GIC_PPI 14 IRQ_TYPE_LEVEL_LOW>,
			     <GIC_PPI 11 IRQ_TYPE_LEVEL_LOW>,
			     <GIC_PPI 10 IRQ_TYPE_LEVEL_LOW>;
	};

	clocks {
		#address-cells = <1>;
		#size-cells = <0>;

		uart_clk: uart-clk {
			compatible = "fixed-clock";
			clock-frequency = <24000000>;
			#clock-cells = <0>;
		};
	};

	pmu {
		compatible = "arm,cortex-a53-pmu";
		interrupts = <GIC_PPI 7 IRQ_TYPE_LEVEL_LOW>;
	};

	/* UART0 - Debug Port */
	serial0: serial@98000000 {
		compatible = "snps,dw-apb-uart";
		reg = <0x0 0x98000000 0x0 0x2000>;
		clocks = <&uart_clk>;
		status = "okay";
	};

	/* USB 2.0 Host */
	usb@9a00000 {
		compatible = "realtek,rtd1296-xhci";
		reg = <0x0 0x9a00000 0x0 0x10000>;
		interrupts = <GIC_SPI 61 IRQ_TYPE_LEVEL_HIGH>;
		status = "okay";
	};

	/* USB 3.0 Host */
	usb@9b00000 {
		compatible = "realtek,rtd1296-xhci";
		reg = <0x0 0x9b00000 0x0 0x10000>;
		interrupts = <GIC_SPI 62 IRQ_TYPE_LEVEL_HIGH>;
		status = "okay";
	};

	/* eMMC */
	mmc@9b0000 {
		compatible = "realtek,rtd1296-dwmshc";
		reg = <0x0 0x9b0000 0x0 0x8000>;
		interrupts = <GIC_SPI 57 IRQ_TYPE_LEVEL_HIGH>;
		status = "okay";
	};

	/* SD Card */
	sd0: sd@9c0000 {
		compatible = "realtek,rtd1296-dwmshc";
		reg = <0x0 0x9c0000 0x0 0x8000>;
		interrupts = <GIC_SPI 56 IRQ_TYPE_LEVEL_HIGH>;
		status = "okay";
	};

	/* PCIe */
	pcie@9a000000 {
		compatible = "realtek,rtd1296-pcie";
		reg = <0x0 0x9a000000 0x0 0x800000>,
		      <0x0 0x1c000000 0x0 0x400000>;
		interrupts = <GIC_SPI 59 IRQ_TYPE_LEVEL_HIGH>;
		#address-cells = <3>;
		#size-cells = <2>;
		device_type = "pci";
		status = "okay";
	};

	/* GMAC (Ethernet) */
	gmac: ethernet@9d00000 {
		compatible = "realtek,rtd1296-gmac";
		reg = <0x0 0x9d00000 0x0 0x10000>;
		interrupts = <GIC_SPI 58 IRQ_TYPE_LEVEL_HIGH>;
		status = "okay";
	};

	/* SATA */
	sata@9d10000 {
		compatible = "realtek,rtd1296-ahci";
		reg = <0x0 0x9d10000 0x0 0x10000>;
		interrupts = <GIC_SPI 60 IRQ_TYPE_LEVEL_HIGH>;
		status = "okay";
	};

	/* GPIO */
	gpio-controller@98030000 {
		compatible = "realtek,rtd1296-gpio";
		reg = <0x0 0x98030000 0x0 0x1000>;
		gpio-controller;
		#gpio-cells = <2>;
	};

	/* HDMI TX */
	hdmitex@9c00000 {
		compatible = "realtek,rtd1296-hdmi";
		reg = <0x0 0x9c00000 0x0 0x40000>;
		interrupts = <GIC_SPI 55 IRQ_TYPE_LEVEL_HIGH>;
		status = "okay";
	};
};
