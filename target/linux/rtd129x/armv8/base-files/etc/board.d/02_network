. /lib/functions/uci-defaults.sh
. /lib/functions/system.sh

rtd129x_setup_interfaces()
{
	local board="$1"
	local ipaddr="192.168.100.1"
	local lan_if="eth0"

	case "$board" in
	linkease,easepi-ars2|\
	realtek,rtd-1296|\
	realtek,rtd-1295)
		# Check if eth1 exists as platform device (indicates dual Ethernet)
		if readlink /sys/class/net/eth1 | grep -qFw platform; then
			lan_if="eth1"
			ucidef_set_interface_wan "eth0" "dhcp"
		fi
		
		# Read default IP from device tree if available
		if [ -e /proc/device-tree/chosen/default-ip ]; then
			ipaddr=$(cat /proc/device-tree/chosen/default-ip)
		fi
		
		if [ "$lan_if" = "eth0" ]; then
			ucidef_set_interface_lan "eth0" "dhcp"
		else
			ucidef_set_interface_lan "eth1" "static"
			ucidef_set_interface "lan" ipaddr "$ipaddr"
			ucidef_set_interface "lan" netmask "255.255.255.0"
		fi
		;;
	*)
		# Default: single LAN interface with DHCP
		ucidef_set_interface_lan 'eth0'
		;;
	esac
}

rtd129x_setup_macs()
{
	local board="$1"
	local lan_mac=""
	local wan_mac=""

	case "$board" in
	linkease,easepi-ars2|\
	realtek,rtd-1296|\
	realtek,rtd-1295)
		# Generate MAC from eMMC CID if available
		if [ -e /sys/class/mmc_host/mmc0/mmc0:0001/cid ]; then
			wan_mac=$(macaddr_generate_from_mmc_cid mmcblk0)
			lan_mac=$(macaddr_add "$wan_mac" 1)
		fi
		;;
	esac

	[ -n "$lan_mac" ] && ucidef_set_interface_macaddr "lan" $lan_mac
	[ -n "$wan_mac" ] && ucidef_set_interface_macaddr "wan" $wan_mac
}

board_config_update
board=$(board_name)
rtd129x_setup_interfaces $board
rtd129x_setup_macs $board
board_config_flush

exit 0
